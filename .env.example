# Required
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional — raises GitHub search rate limits from 10/min to 30/min
GITHUB_TOKEN=your_github_token_here

# Optional — enables Google-based searches via SerpAPI
SERPAPI_KEY=your_serpapi_key_here

# Optional — Firecrawl for JS-rendered page extraction
FIRECRAWL_API_KEY=your_firecrawl_key_here

# Model selection: claude-opus-4-7 | claude-sonnet-4-6
CLAUDE_MODEL=claude-sonnet-4-6

# Local ChromaDB path for persistent memory
MEMORY_PATH=./memory/chroma_db

# How many sources Infiltrator discovers per query
MAX_SOURCES=40

# Maximum depth Ghost will follow links
CRAWL_DEPTH=2
